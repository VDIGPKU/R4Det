ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-11.8/bin/nvcc

cflags = -pthread -B /data/ebtech/miniconda3/envs/t/compiler_compat -Wl,--sysroot=/ -Wsign-compare -DNDEBUG -g -fwrapv -O3 -Wall -Wstrict-prototypes -fPIC -DWITH_CUDA -I/data/tangyousen/bevperception/mmdet3d/ops/deformattn/src -I/data/ebtech/miniconda3/envs/t/lib/python3.8/site-packages/torch/include -I/data/ebtech/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/data/ebtech/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/TH -I/data/ebtech/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/THC -I/usr/local/cuda-11.8/include -I/data/ebtech/miniconda3/envs/t/include/python3.8 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=MultiScaleDeformableAttention -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -DWITH_CUDA -I/data/tangyousen/bevperception/mmdet3d/ops/deformattn/src -I/data/ebtech/miniconda3/envs/t/lib/python3.8/site-packages/torch/include -I/data/ebtech/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/data/ebtech/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/TH -I/data/ebtech/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/THC -I/usr/local/cuda-11.8/include -I/data/ebtech/miniconda3/envs/t/include/python3.8 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DCUDA_HAS_FP16=1 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=MultiScaleDeformableAttention -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_90,code=compute_90 -gencode=arch=compute_90,code=sm_90 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags





build /data/tangyousen/bevperception/mmdet3d/ops/deformattn/build/temp.linux-x86_64-cpython-38/data/tangyousen/bevperception/mmdet3d/ops/deformattn/src/cpu/ms_deform_attn_cpu.o: compile /data/tangyousen/bevperception/mmdet3d/ops/deformattn/src/cpu/ms_deform_attn_cpu.cpp
build /data/tangyousen/bevperception/mmdet3d/ops/deformattn/build/temp.linux-x86_64-cpython-38/data/tangyousen/bevperception/mmdet3d/ops/deformattn/src/cuda/ms_deform_attn_cuda.o: cuda_compile /data/tangyousen/bevperception/mmdet3d/ops/deformattn/src/cuda/ms_deform_attn_cuda.cu
build /data/tangyousen/bevperception/mmdet3d/ops/deformattn/build/temp.linux-x86_64-cpython-38/data/tangyousen/bevperception/mmdet3d/ops/deformattn/src/vision.o: compile /data/tangyousen/bevperception/mmdet3d/ops/deformattn/src/vision.cpp







