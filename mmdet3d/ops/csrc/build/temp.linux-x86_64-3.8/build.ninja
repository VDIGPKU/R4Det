ninja_required_version = 1.3
cxx = c++
nvcc = /home/xiazhongyu/miniconda3/envs/t/bin/nvcc

cflags = -pthread -B /data/ebtech/miniconda3/envs/t/compiler_compat -Wl,--sysroot=/ -Wsign-compare -DNDEBUG -g -fwrapv -O3 -Wall -Wstrict-prototypes -fPIC -Imsmv_sampling -I/home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include -I/home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/TH -I/home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/THC -I/home/xiazhongyu/miniconda3/envs/t/include -I/home/xiazhongyu/miniconda3/envs/t/include/python3.8 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_msmv_sampling_cuda -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -Imsmv_sampling -I/home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include -I/home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/TH -I/home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/THC -I/home/xiazhongyu/miniconda3/envs/t/include -I/home/xiazhongyu/miniconda3/envs/t/include/python3.8 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_msmv_sampling_cuda -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_80,code=compute_80 -gencode=arch=compute_80,code=sm_80 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags





build /data1/tangyousen/bevperception/mmdet3d/ops/csrc/build/temp.linux-x86_64-3.8/msmv_sampling/msmv_sampling.o: compile /data1/tangyousen/bevperception/mmdet3d/ops/csrc/msmv_sampling/msmv_sampling.cpp
build /data1/tangyousen/bevperception/mmdet3d/ops/csrc/build/temp.linux-x86_64-3.8/msmv_sampling/msmv_sampling_backward.o: cuda_compile /data1/tangyousen/bevperception/mmdet3d/ops/csrc/msmv_sampling/msmv_sampling_backward.cu
build /data1/tangyousen/bevperception/mmdet3d/ops/csrc/build/temp.linux-x86_64-3.8/msmv_sampling/msmv_sampling_forward.o: cuda_compile /data1/tangyousen/bevperception/mmdet3d/ops/csrc/msmv_sampling/msmv_sampling_forward.cu







