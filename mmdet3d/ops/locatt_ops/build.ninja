ninja_required_version = 1.3
cxx = c++
nvcc = /home/xiazhongyu/miniconda3/envs/t/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=localattention -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1011\" -isystem /home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include -isystem /home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -isystem /home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/TH -isystem /home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/THC -isystem /home/xiazhongyu/miniconda3/envs/t/include -isystem /home/xiazhongyu/miniconda3/envs/t/include/python3.8 -D_GLIBCXX_USE_CXX11_ABI=0 -fPIC -std=c++17
post_cflags = 
cuda_cflags = -DTORCH_EXTENSION_NAME=localattention -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1011\" -isystem /home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include -isystem /home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -isystem /home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/TH -isystem /home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/include/THC -isystem /home/xiazhongyu/miniconda3/envs/t/include -isystem /home/xiazhongyu/miniconda3/envs/t/include/python3.8 -D_GLIBCXX_USE_CXX11_ABI=0 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr -gencode=arch=compute_80,code=compute_80 -gencode=arch=compute_80,code=sm_80 --compiler-options '-fPIC' -DCUDA_HAS_FP16=1 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ -std=c++17
cuda_post_cflags = 
cuda_dlink_post_cflags = 
ldflags = -shared -L/home/xiazhongyu/miniconda3/envs/t/lib/python3.8/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/home/xiazhongyu/miniconda3/envs/t/lib64 -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags



rule link
  command = $cxx $in $ldflags -o $out

build similar.cuda.o: cuda_compile /data1/tangyousen/bev_opensource/mmdet3d/ops/locatt_ops/similar.cu
build weighting.cuda.o: cuda_compile /data1/tangyousen/bev_opensource/mmdet3d/ops/locatt_ops/weighting.cu
build localAttention.o: compile /data1/tangyousen/bev_opensource/mmdet3d/ops/locatt_ops/localAttention.cpp



build localattention.so: link similar.cuda.o weighting.cuda.o localAttention.o

default localattention.so

